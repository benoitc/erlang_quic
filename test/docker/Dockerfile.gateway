# NAT Gateway with miniupnpd built from source
# Enables: UPnP IGD + NAT-PMP + PCP with private IP support
FROM alpine:3.19 AS builder

RUN apk add --no-cache \
    git \
    make \
    gcc \
    libc-dev \
    linux-headers \
    iptables-dev \
    libnfnetlink-dev \
    bsd-compat-headers \
    util-linux-dev

# Clone and build miniupnpd with all options enabled
WORKDIR /src
RUN git clone --depth 1 https://github.com/miniupnp/miniupnp.git && \
    cd miniupnp/miniupnpd && \
    # Configure with all options
    ./configure --firewall=iptables --ipv6 --igd2 --pcp-peer --leasefile --vendorcfg && \
    make -f Makefile.linux

# Runtime stage
FROM alpine:3.19

RUN apk add --no-cache \
    iptables-legacy \
    ip6tables \
    libip4tc \
    libip6tc \
    iproute2 \
    tcpdump \
    bash \
    libnfnetlink \
    util-linux

# Use iptables-legacy to match miniupnpd's libiptc backend
RUN ln -sf /sbin/iptables-legacy /sbin/iptables && \
    ln -sf /sbin/iptables-legacy-save /sbin/iptables-save && \
    ln -sf /sbin/iptables-legacy-restore /sbin/iptables-restore

# Copy built binary
COPY --from=builder /src/miniupnp/miniupnpd/miniupnpd /usr/sbin/miniupnpd

# Create config directory
RUN mkdir -p /etc/miniupnpd

COPY miniupnpd.conf /etc/miniupnpd/miniupnpd.conf
COPY gateway-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE 5351/udp
EXPOSE 1900/udp

ENTRYPOINT ["/entrypoint.sh"]
