{erl_opts, [
    debug_info,
    warn_export_vars,
    warn_shadow_vars,
    warn_obsolete_guard
]}.

{minimum_otp_vsn, "26"}.

%% In Docker build, quic is built in ../quic relative to /build/app
%% For local development, use path to project root
{deps, [
    {quic, {path, "../quic"}}
]}.

{relx, [
    {release, {quic_dist_test, "0.1.0"}, [
        quic_dist_test,
        quic,
        crypto,
        sasl
    ]},
    {mode, prod},
    {include_erts, true},
    {extended_start_script, true},
    {sys_config_src, "config/sys.config.src"},
    {vm_args_src, "config/vm.args.src"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {mode, prod},
            {include_erts, true}
        ]}
    ]}
]}.
